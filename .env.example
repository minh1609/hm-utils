# Google OAuth2 Client ID
# Create one at https://console.cloud.google.com/ → APIs & Services → Credentials → OAuth 2.0 Client ID
# Type: Web application. Add your local dev URL (e.g. http://localhost:5173) to "Authorized JavaScript origins".
VITE_GOOGLE_CLIENT_ID=YOUR_CLIENT_ID.apps.googleusercontent.com

# The Google Drive folder ID to read docs from.
# It's the long ID in the folder's URL: https://drive.google.com/drive/folders/<FOLDER_ID>
VITE_GOOGLE_FOLDER_ID=1hxiZ5a-W3e8MrNQjbX8kGqWghxcv1cEn
